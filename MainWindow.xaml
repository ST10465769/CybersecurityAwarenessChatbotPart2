<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Awareness Bot"
        Height="700" Width="900"
        MinHeight="550" MinWidth="700"
        Background="#0D1117"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Send Button Style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00B4D8"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0096C7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0077B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="CaretBrush" Value="#00B4D8"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00B4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <!-- Row 0: Header with ASCII art and bot name -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Chat display area -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Input area -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== ROW 0: HEADER ===== -->
        <Border Grid.Row="0"
                BorderBrush="#21262D"
                BorderThickness="0,0,0,1"
                Padding="20,15" Background="#FF2C2231">
            <StackPanel>
                <!-- ASCII Art Logo -->
                <TextBlock x:Name="AsciiArtBlock"
                           FontFamily="Courier New"
                           FontSize="9"
                           Foreground="#00B4D8"
                           TextWrapping="NoWrap"
                           HorizontalAlignment="Center"/>

                <!-- Bot Title -->
                <TextBlock Text="🛡️  CYBERSECURITY AWARENESS BOT"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#E6EDF3"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,4"
                           FontFamily="Segoe UI"/>

                <!-- Subtitle -->
                <TextBlock Text="Protecting South African citizens online — one conversation at a time"
                           FontSize="11"
                           Foreground="#8B949E"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- ===== ROW 1: CHAT DISPLAY ===== -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#0D1117"
                      Padding="16,12">
            <StackPanel x:Name="ChatPanel"
                        Orientation="Vertical"/>
        </ScrollViewer>

        <!-- ===== ROW 2: INPUT AREA ===== -->
        <Border Grid.Row="2"
                Background="#161B22"
                BorderBrush="#21262D"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Text Input Box -->
                <TextBox x:Name="UserInputBox"
                         Grid.Column="0"
                         Style="{StaticResource InputBoxStyle}"
                         Height="{Binding ElementName=SendButton, Mode=OneWay}"
                         KeyDown="UserInputBox_KeyDown"
                         ToolTip="Type your message and press Enter or click Send"/>

                <!-- Send Button -->
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send  ➤"
                        Style="{StaticResource SendButtonStyle}"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>

        <!-- ===== ROW 3: STATUS BAR ===== -->
        <Border Grid.Row="3"
                Background="#0D1117"
                BorderBrush="#21262D"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel"
                           Grid.Column="0"
                           Text="🟢 Bot is ready — type a message to begin"
                           Foreground="#8B949E"
                           FontSize="11"/>
                <TextBlock Grid.Column="1"
                           Text="PROG6221 Part 2 | ST10465769"
                           Foreground="#30363D"
                           FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
